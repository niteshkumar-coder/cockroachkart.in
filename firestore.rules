rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Reusable Global ABAC Primitive Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    // 2. Entity Schema Structure Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email']) 
        && data.keys().size() <= 8
        && data.uid is string && data.uid.size() <= 128
        && data.name is string && data.name.size() <= 256
        && data.email is string && data.email.size() <= 320
        && (!('phone' in data) || data.phone is string && data.phone.size() <= 64)
        && (!('avatarUrl' in data) || data.avatarUrl is string && data.avatarUrl.size() <= 1024)
        && (!('createdAt' in data) || data.createdAt is string || data.createdAt is timestamp)
        && (!('updatedAt' in data) || data.updatedAt is string || data.updatedAt is timestamp);
    }
    
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'userId', 'items', 'total', 'status', 'createdAt'])
        && data.keys().size() <= 14
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.items is list
        && data.total is number && data.total >= 0
        && data.status is string && data.status.size() <= 64;
    }
    
    // 3. Document Route Matches
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidId(userId) 
        && isValidUser(incoming())
        && incoming().uid == request.auth.uid;
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().uid == existing().uid;
    }
    
    match /users/{userId}/orders/{orderId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId)
        && isValidId(userId)
        && isValidId(orderId)
        && isValidOrder(incoming())
        && incoming().userId == request.auth.uid;
      allow update: if isOwner(userId)
        && isValidOrder(incoming())
        && incoming().userId == existing().userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
      allow delete: if false; 
    }
  }
}
