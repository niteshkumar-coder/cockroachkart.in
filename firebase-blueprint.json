{
  "entities": {
    "User": {
      "title": "User",
      "description": "Registered survivor and shopper profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["uid", "name", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Completed purchase order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "shipping": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "couponApplied": { "type": "boolean" },
        "address": { "type": "object" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "userId", "items", "total", "status", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Item in the store visual catalog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "category": { "type": "string" },
        "sizes": { "type": "array" },
        "colors": { "type": "array" },
        "images": { "type": "array" },
        "tag": { "type": "string" },
        "description": { "type": "string" },
        "specs": { "type": "array" },
        "material": { "type": "string" },
        "fit": { "type": "string" },
        "care": { "type": "string" }
      },
      "required": ["id", "name", "price", "category", "images"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile document containing survivor credentials"
    },
    "users/{userId}/orders/{orderId}": {
      "schema": "Order",
      "description": "Purchased merchandise orders ledger details"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Dynamic store web product details"
    }
  }
}
