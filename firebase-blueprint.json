{
  "entities": {
    "User": {
      "title": "User",
      "description": "Registered survivor and shopper profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["uid", "name", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Completed purchase order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "shipping": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "couponApplied": { "type": "boolean" },
        "address": { "type": "object" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "userId", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile document containing survivor credentials"
    },
    "users/{userId}/orders/{orderId}": {
      "schema": "Order",
      "description": "Purchased merchandise orders ledger details"
    }
  }
}
