# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Email Gateway: Configure to send real OTPs to actual Gmail inboxes.
# If configured, emails are dispatched live via nodemailer.
# For Gmail, set HOST="smtp.gmail.com", PORT=587, and PASS to a 16-character Gmail App Password.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Google OAuth 2.0 Single Sign-On (SSO) Credentials
# Add your client coordinates from Google Cloud API credentials dashboard
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

